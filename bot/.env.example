# .env.example - Environment configuration for Agent Marketplace Bot
# Copy this file to .env and fill in your actual values

# =============================================================================
# Chain Configuration
# =============================================================================

# Local Anvil node (default)
RPC_URL=http://localhost:8545

# Base Sepolia (testnet)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Chain ID (31337 = local anvil, 84532 = Base Sepolia testnet)
CHAIN_ID=31337

# =============================================================================
# Contract Addresses
# =============================================================================

# MissionEscrow contract address (deployed)
ESCROW_CONTRACT=0x0000000000000000000000000000000000000000

# USDC token address (Base Sepolia)
USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# =============================================================================
# Agent Configuration
# =============================================================================

# Agent's private key (for signing transactions)
# WARNING: Never commit this to version control!
AGENT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Agent's DID (decentralized identifier)
AGENT_DID=did:key:z6MkhaREgR2p8tN39c5MR4kdL86VJ5xZ2uKqKED7XwJmYxW

# =============================================================================
# GitHub Configuration
# =============================================================================

# GitHub Personal Access Token (repo scope)
GITHUB_TOKEN=ghp_your_github_token_here

# Repository to monitor (format: owner/repo)
GITHUB_REPO=Juwebien/agent-marketplace

# Webhook secret (for verifying webhook payloads)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# =============================================================================
# Bot Configuration
# =============================================================================

# Poll interval in seconds (how often to check for new issues)
POLL_INTERVAL=30

# Deployer creating missions on-chain private key (for)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# =============================================================================
# Optional: Heartbeat
# =============================================================================

# Heartbeat URL for monitoring (optional)
HEARTBEAT_URL=http://localhost:8080/heartbeat
